---
import { getCollection } from "astro:content";
import BlockRenderer from "../components/blocks/BlockRenderer.astro";
import Toolbar from "../components/Toolbar.astro";
import TailwindShowcase from "../components/showcase/TailwindShowcase.astro";
import { ShadcnShowcase } from "../components/showcase/ShadcnShowcase";
import "../styles/global.css";

import type {
	StrapiHomepage,
	StrapiGlobal,
	StrapiContentHeroComponent,
} from "../types/strapi";

function preprocessSingleType(collection: any[]) {
	return collection[0]?.data || null;
}

let homepage: StrapiHomepage | null = null;
let global: StrapiGlobal | null = null;

try {
	homepage = await getCollection("homepage").then(preprocessSingleType);
	global = await getCollection("global").then(preprocessSingleType);
} catch (error) {
	console.error("Error loading Strapi content:", error);
}

if (!homepage) {
	homepage = {
		id: 1,
		documentId: "homepage",
		title: "Astro x Strapi Starter",
		hero: {
			__component: "blocks.hero",
			id: 0,
			title: "Build faster with Astro & Strapi",
			subtitle:
				"A production-ready starter with Astro 5, Strapi CMS, Tailwind CSS 4, and shadcn/ui — dark mode included.",
			content: [
				{
					type: "paragraph",
					children: [
						{
							text: "Content-driven sites with exceptional performance. Load content from Strapi, render rich blocks, style with Tailwind or shadcn/ui — everything wired up and ready to ship.",
							type: "text",
						},
					],
				},
			],
			cta: {
				label: "Explore Features",
				url: "#features",
			},
		},
		sections: [
			{
				__component: "blocks.text",
				id: 1,
				title: "What's inside",
				content: [
					{
						type: "paragraph",
						children: [
							{
								text: "⚡ Astro 5 with SSR — fast builds, zero-JS by default, islands architecture",
								type: "text",
							},
						],
					},
					{
						type: "paragraph",
						children: [
							{
								text: "📦 Strapi Loader & Blocks — auto-load collections and render rich text out of the box",
								type: "text",
							},
						],
					},
					{
						type: "paragraph",
						children: [
							{
								text: "🎨 Tailwind CSS 4 + shadcn/ui — pick your approach, both are set up and ready",
								type: "text",
							},
						],
					},
					{
						type: "paragraph",
						children: [
							{
								text: "🌗 Dark mode — system-aware, toggleable, with branded theme tokens throughout",
								type: "text",
							},
						],
					},
				],
			},
		],
		examples: [
			{
				__component: "blocks.quote",
				id: 1,
				quote: "The fastest way to go from a Strapi backend to a polished, production-ready frontend.",
				author: "Sensinum Team",
			},
			{
				__component: "blocks.cta",
				id: 2,
				title: "Strapi Loader for Astro",
				classes: "rounded-xl border border-brand-200 bg-brand-50/60 p-8 my-8 text-foreground dark:border-brand-800/40 dark:bg-brand-950/20",
				shields: [
					{
						label: "NPM Version",
						url: "https://img.shields.io/npm/v/%40sensinum%2Fastro-strapi-loader"
					},
					{
						label: "NPM Downloads",
						url: "https://img.shields.io/npm/dm/%40sensinum%2Fastro-strapi-loader"
					},
				],
				description:
					"Seamlessly load Strapi collections into Astro's content layer. Type-safe, automatic schema generation, zero boilerplate.",
				cta: {
					label: "View on GitHub",
					url: "https://github.com/VirtusLab-Open-Source/astro-strapi-loader",
				},
			},
			{
				__component: "blocks.cta",
				id: 3,
				title: "Strapi Blocks for Astro",
				classes: "rounded-xl border border-violet-200 bg-violet-50/60 p-8 my-8 text-foreground dark:border-violet-700/40 dark:bg-violet-950/20",
				shields: [
					{
						label: "NPM Version",
						url: "https://img.shields.io/npm/v/%40sensinum%2Fastro-strapi-blocks"
					},
					{
						label: "NPM Downloads",
						url: "https://img.shields.io/npm/dm/%40sensinum%2Fastro-strapi-blocks"
					},
				],
				description:
					"Render Strapi's rich text blocks as Astro components. Headings, lists, images, links — all handled with customizable themes.",
				cta: {
					label: "View on GitHub",
					url: "https://github.com/VirtusLab-Open-Source/astro-strapi-blocks",
				},
			},
			{
				__component: "blocks.cta",
				id: 4,
				title: "Ready to ship?",
				classes: "rounded-xl border border-border bg-muted/50 p-8 my-8 text-foreground",
				description:
					"Clone the starter, connect Strapi, and deploy to Vercel or Netlify in minutes.",
				cta: {
					label: "Read the Docs",
					url: "https://docs.astro.build",
				},
			},
		],
		publishedAt: new Date().toISOString(),
		updatedAt: new Date().toISOString(),
	};
}

const pageTitle = homepage?.title || "Astro + Strapi Starter";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
		<meta
			name="description"
			content="Production-ready starter with Astro 5, Strapi CMS, Tailwind CSS 4, shadcn/ui, and dark mode."
		/>
		<script is:inline>
			(function() {
				var stored = localStorage.getItem('theme');
				var systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
				if (stored === 'dark' || (!stored && systemDark)) {
					document.documentElement.classList.add('dark');
				}
				var uiMode = localStorage.getItem('ui-mode') || 'tailwind';
				document.documentElement.setAttribute('data-ui', uiMode);
			})();
		</script>
	</head>

	<body class="min-h-screen flex flex-col bg-background text-foreground">
		<Toolbar />

		<main class="flex-1">
			{
				homepage?.hero && (
					<BlockRenderer
						data={homepage.hero as StrapiContentHeroComponent}
					/>
				)
			}

			<div class="max-w-4xl mx-auto px-4 sm:px-6 py-16">
				{
					homepage?.sections?.map((section) => (
						<BlockRenderer data={section} />
					))
				}

				<section id="demo-blocks" class="mt-16">
					<div class="flex items-center gap-4 mb-10">
						<div class="h-px flex-1 bg-border" />
						<h2 class="text-2xl font-bold text-foreground whitespace-nowrap">
							Packages & Tools
						</h2>
						<div class="h-px flex-1 bg-border" />
					</div>

					{
						homepage?.examples?.map((example) => (
							<BlockRenderer data={example} />
						))
					}
				</section>

				<section id="component-showcase" class="mt-20">
					<div class="flex items-center gap-4 mb-4">
						<div class="h-px flex-1 bg-border" />
						<h2 class="text-2xl font-bold text-foreground whitespace-nowrap">
							Component Showcase
						</h2>
						<div class="h-px flex-1 bg-border" />
					</div>
					<p class="text-center text-muted-foreground mb-12">
						Switch between <strong class="text-foreground">pure Tailwind</strong> and <strong class="text-foreground">shadcn/ui</strong> using the toggle in the header
					</p>

					<TailwindShowcase />
					<ShadcnShowcase client:load />
				</section>
			</div>
		</main>

		<footer class="border-t border-border bg-muted/50 py-8 mt-8">
			<div class="max-w-4xl mx-auto px-4 sm:px-6 text-center text-sm text-muted-foreground">
				<p>
					Built with 💚 by
					<a href="https://www.sensinum.com" class="text-primary font-semibold hover:text-primary/80 transition-colors">Sensinum</a>
					a 
					<a href="https://www.virtuslab.com" class="text-primary font-semibold hover:text-primary/80 transition-colors">VirtusLab Group</a> 
					company
				</p>
			</div>
		</footer>
	</body>
</html>
