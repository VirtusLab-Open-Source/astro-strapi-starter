---
import TailwindLogo from "./icons/TailwindLogo.astro";
import ShadcnLogo from "./icons/ShadcnLogo.astro";

type Props = {
  variant?: "text" | "responsive";
};

const { variant = "text" } = Astro.props;
const isResponsive = variant === "responsive";
---

<div class="ui-toggle inline-flex rounded-lg border border-border bg-muted p-0.5 text-sm">
  <button
    data-ui-select="tailwind"
    aria-label="Switch to Tailwind CSS"
    class="rounded-md px-3 py-1.5 font-medium transition-colors text-muted-foreground data-[active]:bg-background data-[active]:text-foreground data-[active]:shadow-sm flex items-center gap-1.5"
  >
    {isResponsive ? (
      <>
        <TailwindLogo class="size-4 sm:hidden" />
        <span class="hidden sm:inline">Tailwind</span>
      </>
    ) : (
      <span>Tailwind</span>
    )}
  </button>
  <button
    data-ui-select="shadcn"
    aria-label="Switch to shadcn/ui"
    class="rounded-md px-3 py-1.5 font-medium transition-colors text-muted-foreground data-[active]:bg-background data-[active]:text-foreground data-[active]:shadow-sm flex items-center gap-1.5"
  >
    {isResponsive ? (
      <>
        <ShadcnLogo class="size-4 sm:hidden" />
        <span class="hidden sm:inline">shadcn/ui</span>
      </>
    ) : (
      <span>shadcn/ui</span>
    )}
  </button>
</div>

<script>
  function initUIToggle() {
    const html = document.documentElement;
    const allButtons = document.querySelectorAll("[data-ui-select]");

    function syncAll(mode: string) {
      allButtons.forEach((b) => {
        if (b.getAttribute("data-ui-select") === mode) {
          b.setAttribute("data-active", "");
        } else {
          b.removeAttribute("data-active");
        }
      });
    }

    syncAll(html.getAttribute("data-ui") || "tailwind");

    allButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const mode = btn.getAttribute("data-ui-select")!;
        html.setAttribute("data-ui", mode);
        localStorage.setItem("ui-mode", mode);
        syncAll(mode);
      });
    });
  }

  initUIToggle();
  document.addEventListener("astro:after-swap", initUIToggle);
</script>
