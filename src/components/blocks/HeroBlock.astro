---
import { Image } from "astro:assets";
import { StrapiBlocks } from "@sensinum/astro-strapi-blocks";

import type { StrapiBlockField, StrapiContentHeroComponent } from "../../types/strapi";
import { buildMediaUrl } from "../../utils";

type Props = {
    data: StrapiContentHeroComponent['hero'];
};

const { data } = Astro.props;
---

<div class="relative bg-linear-to-br from-brand-50 to-violet-50 dark:from-brand-950/40 dark:to-violet-950/30 py-20 lg:py-32 overflow-hidden">
    {
        data.background && (
            <div class="absolute inset-0 z-0">
                <Image
                    src={buildMediaUrl(data.background.url)}
                    alt={data.background.alternativeText || ""}
                    class="w-full h-full object-cover opacity-30 dark:opacity-20"
                />
                <div class="absolute inset-0 bg-background/60 dark:bg-background/70" />
            </div>
        )
    }

    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center">
            <Image
                src="https://www.sensinum.com/img/open-source/strapi-astro-blocks/logo.png"
                alt="Astro x Strapi Integrations by Sensinum"
                width={140}
                height={140}
                class="mx-auto mb-8"
            />

            <h1 class="text-4xl lg:text-5xl font-bold text-foreground leading-tight mb-6">
                {data.title}
            </h1>
            {
                data.subtitle && (
                    <p class="text-xl lg:text-2xl mb-8 max-w-3xl mx-auto text-muted-foreground font-light">
                        {data.subtitle}
                    </p>
                )
            }
            {
                data.content && (
                    <StrapiBlocks class="text-lg mb-10 max-w-2xl mx-auto text-muted-foreground" data={data.content as StrapiBlockField} />
                )
            }
            {
                data.cta && (
                    <div class="flex flex-wrap justify-center gap-4">
                        <a
                            href={data.cta.url}
                            class="inline-block bg-primary hover:bg-primary/90 text-primary-foreground font-semibold py-3 px-8 rounded-lg transition-colors shadow-lg text-lg"
                        >
                            {data.cta.label}
                        </a>
                        <a
                            href="#component-showcase"
                            class="inline-block border border-border hover:bg-accent text-foreground font-semibold py-3 px-8 rounded-lg transition-colors"
                        >
                            Component Showcase
                        </a>
                    </div>
                )
            }
        </div>
    </div>
</div>
